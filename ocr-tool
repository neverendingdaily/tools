/* ── NOISE FILTER ── */

// 日本語文字（ひらがな・カタカナ・漢字・全角記号）を含むか判定
function hasJapanese(s){
  return /[\u3040-\u309f\u30a0-\u30bf\u4e00-\u9fff\u3400-\u4dbf\uff01-\uff9f\u3000-\u303f]/.test(s);
}

function cleanOcrText(text){
  var lines=text.split('\n');
  var out=[];

  for(var i=0;i<lines.length;i++){
    var line=lines[i];
    var trimmed=line.trim();

    // ── 空行はそのまま残す（段落間のスペース保持）──
    if(trimmed===''){out.push('');continue;}

    // ── 固定ノイズパターン（優先除去）──

    // "Page N" 行
    if(/^Page\s+\d+\s*$/.test(trimmed)){continue;}

    // dマガジン系URL
    if(/https?:\/\/dmagazine\.docomo\.ne\.jp\//i.test(trimmed)){continue;}

    // dマガジンバナー
    if(/dマガジン/.test(trimmed)&&/読み放題/.test(trimmed)){continue;}

    // FireShot 系
    if(/^Captured by FireShot/i.test(trimmed)){continue;}
    if(/https?:\/\/(www\.)?getfireshot\.com/i.test(trimmed)){continue;}

    // 任意のURL（http/httpsで始まる行）
    if(/^https?:\/\/\S+$/.test(trimmed)){continue;}

    // ── 日本語ゼロ の行を除去 ──
    // 日本語が一文字でもあれば残す（英数字混在OK）
    if(!hasJapanese(trimmed)){
      // 例外: 記号・絵文字だけの区切り行は残す（▲ ★ ● など）
      // ただし純粋な英数字のみ行・数字のみ行は除去
      // 全角記号・絵文字を含む場合は残す
      var hasSymbol=/[▲▼●○◎★☆■□♡♥◆◇→←↑↓※†‡…・。、！？【】『』「」（）〈〉《》〔〕～＆＠＃]/.test(trimmed);
      var hasEmoji=/[\u{1F300}-\u{1FFFF}]/u.test(trimmed);
      if(!hasSymbol&&!hasEmoji){continue;}
    }

    out.push(line); // 元の行（インデント保持）
  }

  // 先頭・末尾の空行を除去
  while(out.length&&!out[0].trim())out.shift();
  while(out.length&&!out[out.length-1].trim())out.pop();

  // 連続する空行を1行にまとめる
  var result=[];
  var prevBlank=false;
  for(var j=0;j<out.length;j++){
    var isBlank=!out[j].trim();
    if(isBlank&&prevBlank)continue;
    result.push(out[j]);
    prevBlank=isBlank;
  }

  return result.join('\n');
}

/* ── OCR PROMPT ── */
function buildPrompt(){
  if(mode==='full')return 'この画像またはPDFに含まれるすべてのテキストを、レイアウト・改行・段落・見出しの構造をできる限り忠実に保ちながら、そのまま抽出してください。テキスト以外の説明や注釈は一切不要です。抽出したテキストのみを出力してください。';
  if(mode==='clean')return 'この画像またはPDFに含まれるすべてのテキストを抽出してください。OCRノイズや不要な改行を除去し、自然に読みやすい形に整形して出力してください。テキスト以外の説明は不要です。';
  return 'この画像またはPDFに含まれるすべてのテキストを抽出し、Markdown形式（見出し#・##、太字**、リスト-）に変換して出力してください。テキスト以外の説明は不要です。';
}

/* ── PDF UPLOAD ── */
async function uploadPdf(f,key){
  var buf=await f.arrayBuffer(),u8=new Uint8Array(buf);
  var b='ocr_b_'+Date.now(),meta=JSON.stringify({file:{display_name:f.name}});
  var enc=new TextEncoder();
  var h=enc.encode('--'+b+'\r\nContent-Type: application/json; charset=UTF-8\r\n\r\n'+meta+'\r\n--'+b+'\r\nContent-Type: '+f.type+'\r\n\r\n');
  var t=enc.encode('\r\n--'+b+'--');
  var body=new Uint8Array(h.length+u8.length+t.length);body.set(h,0);body.set(u8,h.length);body.set(t,h.length+u8.length);
  var r=await fetch('https://generativelanguage.googleapis.com/upload/v1beta/files?uploadType=multipart&key='+key,{method:'POST',headers:{'Content-Type':'multipart/related; boundary='+b},body:body.buffer});
  if(!r.ok){var e=await r.json().catch(function(){return{};});throw new Error('PDFアップロード失敗: '+(e&&e.error&&e.error.message?e.error.message:'HTTP '+r.status));}
  var d=await r.json();if(!d.file||!d.file.uri)throw new Error('URI取得失敗');return d.file.uri;
}
function b64(f){return new Promise(function(res,rej){var r=new FileReader();r.onload=function(){res(r.result.split(',')[1]);};r.onerror=rej;r.readAsDataURL(f);});}

/* ── RUN ── */
runBtn.addEventListener('click',run);
async function run(){
  var key=document.getElementById('ak').value.trim();
  var model=document.getElementById('mi').value.trim();
  runBtn.classList.add('ld');runBtn.disabled=true;
  showResult('load');
  try{
    var parts=[{text:buildPrompt()}];
    for(var i=0;i<files.length;i++){
      var f=files[i];
      document.getElementById('ldm').textContent=(f.type==='application/pdf'?'PDF送信中':'画像読込中')+' ('+(i+1)+'/'+files.length+')';
      if(f.type==='application/pdf'){var uri=await uploadPdf(f,key);parts.push({file_data:{mime_type:'application/pdf',file_uri:uri}});}
      else{var d=await b64(f);parts.push({inline_data:{mime_type:f.type,data:d}});}
    }
    document.getElementById('ldm').textContent='Gemini がテキストを解析中...';
    var r=await fetch('https://generativelanguage.googleapis.com/v1beta/models/'+model+':generateContent?key='+key,
      {method:'POST',headers:{'Content-Type':'application/json'},
       body:JSON.stringify({contents:[{role:'user',parts:parts}],generationConfig:{temperature:.05,maxOutputTokens:8192}})});
    if(!r.ok){var ed=await r.json().catch(function(){return{};});throw new Error(ed&&ed.error&&ed.error.message?ed.error.message:'HTTP '+r.status);}
    var dd=await r.json();
    var raw=dd&&dd.candidates&&dd.candidates[0]&&dd.candidates[0].content&&dd.candidates[0].content.parts&&dd.candidates[0].content.parts[0]&&dd.candidates[0].content.parts[0].text;
    if(!raw)throw new Error('応答が空でした。別のモデル名を試してください。');

    // ── Clean noise ──
    var txt=cleanOcrText(raw);

    document.getElementById('rb').value=txt;
    document.getElementById('cc').textContent=txt.length.toLocaleString()+' 文字（ノイズ除去済み）';
    var now=new Date().toLocaleString('ja-JP');
    var fname=files.map(function(f){return f.name;}).join(', ');
    document.getElementById('rm').textContent=now+' ／ '+model;
    showResult('res');

    // save to history
    addHistory({
      id:Date.now()+'_'+Math.random().toString(36).slice(2),
      name:fname,
      date:now,
      model:model,
      chars:txt.length,
      text:txt
    });

  }catch(e){
    showResult('err');
    document.getElementById('erm').textContent=fmtErr(e.message);
  }finally{
    runBtn.classList.remove('ld');updateRun();
  }
}

