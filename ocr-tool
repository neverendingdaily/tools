document.getElementById('fb').addEventListener('click',fetchModels);
async function fetchModels(){
  document.getElementById('fb').disabled=true;
  document.getElementById('fst').textContent='取得中...';
  document.getElementById('fst').className='fetch-st';
  try{
    var r=await fetch('https://generativelanguage.googleapis.com/v1beta/models?key='+document.getElementById('ak').value.trim()+'&pageSize=100',{signal:AbortSignal.timeout(10000)});
    if(!r.ok)throw new Error('HTTP '+r.status);
    var d=await r.json();
    var ms=(d.models||[]).filter(function(m){return m.supportedGenerationMethods&&m.supportedGenerationMethods.includes('generateContent');});
    if(!ms.length)throw new Error('モデルが見つかりません');
    var dl=document.getElementById('ml');dl.innerHTML='';
    ms.forEach(function(m){var id=m.name.replace('models/','');var o=document.createElement('option');o.value=id;dl.appendChild(o);});
    var best=ms.find(function(m){var id=m.name.replace('models/','');return id.includes('flash')&&!id.includes('lite')&&!id.includes('8b')&&!id.includes('preview');});
    if(!best)best=ms.find(function(m){return m.name.includes('flash');});
    if(best)document.getElementById('mi').value=best.name.replace('models/','');
    document.getElementById('fst').textContent='✓ '+ms.length+' モデル取得済み';
    document.getElementById('fst').className='fetch-st ok';
    fetchDone=true;
  }catch(e){
    document.getElementById('fst').textContent='⚠ 取得失敗 — モデル名を手動で入力してください';
    document.getElementById('fst').className='fetch-st err';
  }
  document.getElementById('fb').disabled=!apiOk();
}

