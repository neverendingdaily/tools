  var u=URL.createObjectURL(bl);var a=document.createElement('a');a.href=u;a.download='ocr-'+Date.now()+'.txt';a.click();URL.revokeObjectURL(u);
});

/* ── UTILS ── */
function flash(btn){var o=btn.textContent;btn.textContent='✓ コピー済み';btn.classList.add('ok');setTimeout(function(){btn.textContent=o;btn.classList.remove('ok');},2000);}
function esc(s){return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');}
function fmtErr(msg){
  if(!msg)return '不明なエラー';
  if(msg.includes('not found')||msg.includes('no longer')||msg.includes('deprecated'))
    return '指定したモデルが見つかりません。\n\n'+msg+'\n\n→ モデル名を変更してください。\n例: gemini-1.5-pro-002 / gemini-1.5-flash-002';
  if(msg.includes('API_KEY_INVALID')||msg.includes('API key not valid'))return 'APIキーが無効です。';
  if(msg.includes('RESOURCE_EXHAUSTED'))return 'レート制限に達しました。しばらく待ってから再試行してください。';
  return msg;
}

